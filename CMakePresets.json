{
    "version": 6,
    "configurePresets": [
        {
            "name": "macos-arm64-debug",
            "displayName": "macOS arm64 Static Debug (Homebrew, Ninja)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_OSX_ARCHITECTURES": "arm64",
                "AMSFTP_BUILD_TESTS": "ON",
                "AMSFTP_LINK_MODE": "static"
            }
        },
        {
            "name": "macos-arm64-release",
            "displayName": "macOS arm64 Static Release (Homebrew, Ninja)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            },
            "environment": {
                "PKG_CONFIG_ALL_STATIC": "1",
                "PKG_CONFIG_PATH": "/opt/homebrew/opt/zlib/lib/pkgconfig:/opt/homebrew/opt/curl/lib/pkgconfig:/opt/homebrew/lib/pkgconfig"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_OSX_ARCHITECTURES": "arm64",
                "CMAKE_PREFIX_PATH": "/opt/homebrew;/opt/homebrew/opt/zlib;/opt/homebrew/opt/curl",
                "CMAKE_FIND_LIBRARY_SUFFIXES": ".a",
                "AMSFTP_BUILD_TESTS": "ON",
                "AMSFTP_LINK_MODE": "static",
                "ZLIB_ROOT": "/opt/homebrew/opt/zlib",
                "CURL_ROOT": "/opt/homebrew/opt/curl"
            }
        },
        {
            "name": "windows-msvc-debug",
            "displayName": "Windows MSVC Static Debug (Ninja, vcpkg)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "environment": {
                "VCPKG_ROOT": "D:/Compiler/vcpkg",
                "RC": "D:/Compiler/LLVM/bin/llvm-rc.exe"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "clang-cl",
                "CMAKE_CXX_COMPILER": "clang-cl",
                "CMAKE_RC_COMPILER": "D:/Compiler/LLVM/bin/llvm-rc.exe",
                "CMAKE_MT": "D:/Compiler/LLVM/bin/llvm-mt.exe",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "AMSFTP_BUILD_TESTS": "ON",
                "AMSFTP_LINK_MODE": "static",
                "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDebug",
                "VCPKG_TARGET_TRIPLET": "x64-windows-static",
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
            }
        },
        {
            "name": "windows-msvc-release",
            "displayName": "Windows MSVC Static Release (Ninja, vcpkg)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "environment": {
                "VCPKG_ROOT": "D:/Compiler/vcpkg",
                "RC": "D:/Compiler/LLVM/bin/llvm-rc.exe"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_C_COMPILER": "clang-cl",
                "CMAKE_CXX_COMPILER": "clang-cl",
                "CMAKE_RC_COMPILER": "D:/Compiler/LLVM/bin/llvm-rc.exe",
                "CMAKE_MT": "D:/Compiler/LLVM/bin/llvm-mt.exe",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "AMSFTP_BUILD_TESTS": "ON",
                "AMSFTP_LINK_MODE": "static",
                "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded",
                "VCPKG_TARGET_TRIPLET": "x64-windows-static",
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "macos-arm64-debug",
            "configurePreset": "macos-arm64-debug"
        },
        {
            "name": "macos-arm64-release",
            "configurePreset": "macos-arm64-release"
        },
        {
            "name": "windows-msvc-debug",
            "configurePreset": "windows-msvc-debug"
        },
        {
            "name": "windows-msvc-release",
            "configurePreset": "windows-msvc-release"
        }
    ],
    "testPresets": [
        {
            "name": "macos-arm64-debug",
            "configurePreset": "macos-arm64-debug"
        },
        {
            "name": "macos-arm64-release",
            "configurePreset": "macos-arm64-release"
        },
        {
            "name": "windows-msvc-debug",
            "configurePreset": "windows-msvc-debug"
        },
        {
            "name": "windows-msvc-release",
            "configurePreset": "windows-msvc-release"
        }
    ]
}
