#include "domain/var/VarDomainService.hpp"
#include "domain/host/HostDomainService.hpp"
#include "foundation/tools/enum_related.hpp"
#include "foundation/tools/string.hpp"
#include <algorithm>
#include <unordered_set>

namespace AMDomain::var {
ECM VarDomainService::ReplaceAll(DomainDict vars_by_domain) {
  DomainDict normalized;
  normalized.reserve(vars_by_domain.size() + 1);
  normalized[AMDomain::var::kPublic] = DomainVars{};

  for (auto &domain_entry : vars_by_domain) {
    if (!IsValidDomainName_(domain_entry.first)) {
      continue;
    }
    DomainVars &target = normalized[domain_entry.first];
    for (auto &var_entry : domain_entry.second) {
      if (!AMDomain::var::IsValidVarname(var_entry.first)) {
        continue;
      }
      target[var_entry.first] = std::move(var_entry.second);
    }
  }

  std::lock_guard<std::mutex> lock(mutex_);
  vars_by_domain_ = std::move(normalized);
  return Ok();
}

VarDomainService::DomainDict VarDomainService::Snapshot() const {
  std::lock_guard<std::mutex> lock(mutex_);
  return vars_by_domain_;
}

const VarDomainService::DomainDict &VarDomainService::ConstRef() const {
  return vars_by_domain_;
}

VarInfo VarDomainService::GetVar(const std::string &domain,
                                 const std::string &name) const {
  if (!IsValidDomainName_(domain) || !AMDomain::var::IsValidVarname(name)) {
    return {};
  }
  std::lock_guard<std::mutex> lock(mutex_);
  auto domain_it = vars_by_domain_.find(domain);
  if (domain_it == vars_by_domain_.end()) {
    return {};
  }
  auto var_it = domain_it->second.find(name);
  if (var_it == domain_it->second.end()) {
    return {};
  }
  return {domain, name, var_it->second};
}

std::vector<VarInfo>
VarDomainService::FindByName(const std::string &name) const {
  std::vector<VarInfo> out;
  if (!AMDomain::var::IsValidVarname(name)) {
    return out;
  }
  std::lock_guard<std::mutex> lock(mutex_);
  out.reserve(vars_by_domain_.size());
  for (const auto &domain_entry : vars_by_domain_) {
    auto it = domain_entry.second.find(name);
    if (it == domain_entry.second.end()) {
      continue;
    }
    out.push_back({domain_entry.first, name, it->second});
  }
  std::sort(out.begin(), out.end(), [](const VarInfo &a, const VarInfo &b) {
    return a.domain < b.domain;
  });
  return out;
}

std::vector<VarInfo>
VarDomainService::ListByDomain(const std::string &domain) const {
  std::vector<VarInfo> out;
  if (!IsValidDomainName_(domain)) {
    return out;
  }
  std::lock_guard<std::mutex> lock(mutex_);
  auto domain_it = vars_by_domain_.find(domain);
  if (domain_it == vars_by_domain_.end()) {
    return out;
  }
  out.reserve(domain_it->second.size());
  for (const auto &entry : domain_it->second) {
    out.push_back({domain, entry.first, entry.second});
  }
  std::sort(out.begin(), out.end(), [](const VarInfo &a, const VarInfo &b) {
    return a.varname < b.varname;
  });
  return out;
}

std::vector<std::string> VarDomainService::ListDomains() const {
  std::vector<std::string> domains;
  std::lock_guard<std::mutex> lock(mutex_);
  domains.reserve(vars_by_domain_.size());
  for (const auto &entry : vars_by_domain_) {
    domains.push_back(entry.first);
  }
  std::sort(domains.begin(), domains.end());
  return domains;
}

bool VarDomainService::HasDomain(const std::string &domain) const {
  if (!IsValidDomainName_(domain)) {
    return false;
  }
  std::lock_guard<std::mutex> lock(mutex_);
  return vars_by_domain_.find(domain) != vars_by_domain_.end();
}

bool VarDomainService::HasVar(const std::string &domain,
                              const std::string &name) const {
  if (!IsValidDomainName_(domain) || !AMDomain::var::IsValidVarname(name)) {
    return false;
  }
  std::lock_guard<std::mutex> lock(mutex_);
  auto domain_it = vars_by_domain_.find(domain);
  if (domain_it == vars_by_domain_.end()) {
    return false;
  }
  return domain_it->second.find(name) != domain_it->second.end();
}

ECM VarDomainService::SetVar(const VarInfo &info, bool create_domain) {
  ECM valid = info.IsValid();
  if (valid.first != EC::Success) {
    return valid;
  }
  if (!IsValidDomainName_(info.domain)) {
    return Err(EC::InvalidArg, "invalid domain");
  }
  if (!AMDomain::var::IsValidVarname(info.varname)) {
    return Err(EC::InvalidArg, "invalid variable name");
  }

  std::lock_guard<std::mutex> lock(mutex_);
  auto domain_it = vars_by_domain_.find(info.domain);
  if (domain_it == vars_by_domain_.end() && !create_domain) {
    return Err(EC::InvalidArg, "domain not found");
  }
  vars_by_domain_[info.domain][info.varname] = info.varvalue;
  return Ok();
}

ECM VarDomainService::DeleteVar(const std::string &domain,
                                const std::string &name) {
  if (!IsValidDomainName_(domain) || !AMDomain::var::IsValidVarname(name)) {
    return Err(EC::InvalidArg, "invalid domain or variable name");
  }

  std::lock_guard<std::mutex> lock(mutex_);
  auto domain_it = vars_by_domain_.find(domain);
  if (domain_it == vars_by_domain_.end()) {
    return Err(EC::InvalidArg, "domain not found");
  }
  auto var_it = domain_it->second.find(name);
  if (var_it == domain_it->second.end()) {
    return Err(EC::InvalidArg, "variable not found");
  }
  domain_it->second.erase(var_it);
  return Ok();
}

ECM VarDomainService::DeleteVarAll(const std::string &name,
                                   std::vector<VarInfo> *removed) {
  if (!AMDomain::var::IsValidVarname(name)) {
    return Err(EC::InvalidArg, "invalid variable name");
  }
  std::lock_guard<std::mutex> lock(mutex_);
  bool any_removed = false;
  for (auto &domain_entry : vars_by_domain_) {
    auto it = domain_entry.second.find(name);
    if (it == domain_entry.second.end()) {
      continue;
    }
    if (removed) {
      removed->push_back({domain_entry.first, it->first, it->second});
    }
    domain_entry.second.erase(it);
    any_removed = true;
  }
  if (!any_removed) {
    return Err(EC::InvalidArg, "variable not found");
  }
  return Ok();
}

std::vector<std::string> VarDomainService::ListNames() const {
  std::lock_guard<std::mutex> lock(mutex_);
  std::unordered_set<std::string> seen;
  std::vector<std::string> names;
  for (const auto &domain_entry : vars_by_domain_) {
    for (const auto &entry : domain_entry.second) {
      if (seen.insert(entry.first).second) {
        names.push_back(entry.first);
      }
    }
  }
  std::sort(names.begin(), names.end());
  return names;
}

std::string
VarDomainService::SubstitutePathLike(const std::string &input,
                                     const std::string &current_domain) const {
  if (input.empty()) {
    return input;
  }

  const std::string domain = AMStr::Strip(current_domain);
  std::string output;
  output.reserve(input.size());

  std::lock_guard<std::mutex> lock(mutex_);
  auto append_lookup = [&](const AMDomain::var::VarRef &ref,
                           const std::string &fallback) {
    if (ref.varname.empty()) {
      output.append(fallback);
      return;
    }

    auto append_from_domain = [&](const std::string &target_domain) -> bool {
      auto domain_it = vars_by_domain_.find(target_domain);
      if (domain_it == vars_by_domain_.end()) {
        return false;
      }
      auto var_it = domain_it->second.find(ref.varname);
      if (var_it == domain_it->second.end()) {
        return false;
      }
      output.append(var_it->second);
      return true;
    };

    if (ref.explicit_domain) {
      if (append_from_domain(ref.domain)) {
        return;
      }
      output.append(fallback);
      return;
    }

    if (!domain.empty() && append_from_domain(domain)) {
      return;
    }
    if (append_from_domain(AMDomain::var::kPublic)) {
      return;
    }
    output.append(fallback);
  };

  for (size_t i = 0; i < input.size(); ++i) {
    const char ch = input[i];
    if (ch == '`' && i + 1 < input.size() && input[i + 1] == '$') {
      output.push_back('$');
      ++i;
      continue;
    }
    if (ch != '$') {
      output.push_back(ch);
      continue;
    }
    if (i + 1 >= input.size()) {
      output.push_back('$');
      continue;
    }

    size_t ref_end = i;
    AMDomain::var::VarRef ref{};
    if (!AMDomain::var::ParseVarRefAt(input, i, input.size(), true, true, &ref_end,
                                 &ref) ||
        ref_end <= i) {
      output.push_back('$');
      continue;
    }

    const std::string token = input.substr(i, ref_end - i);
    append_lookup(ref, token);
    i = ref_end - 1;
  }

  return output;
}

void VarDomainService::SubstitutePathLike(
    std::vector<std::string> *inputs, const std::string &current_domain) const {
  if (!inputs) {
    return;
  }
  for (std::string &item : *inputs) {
    item = SubstitutePathLike(item, current_domain);
  }
}

bool VarDomainService::IsValidDomainName_(const std::string &domain) const {
  if (domain == AMDomain::var::kPublic) {
    return true;
  }
  return AMDomain::host::HostService::ValidateNickname(domain);
}
} // namespace AMDomain::var

