size_t TransferAppService::RemoveCachedTransferSets(
    const std::vector<size_t> &set_indices, std::vector<ECM> *warnings) {
  (void)set_indices;
  if (warnings) {
    warnings->push_back(CacheDeprecatedError_());
  }
  return 0;
}

