ECM TransferAppService::SubmitCachedTransferSetsWithControl(
    bool quiet, bool is_async, AMDomain::client::amf control_token,
    TransferConfirmPolicy confirm_policy, const WildcardConfirmFn &confirm_wildcard,
    std::vector<ECM> *warnings) {
  (void)quiet;
  (void)is_async;
  (void)control_token;
  (void)confirm_policy;
  (void)confirm_wildcard;
  if (warnings) {
    warnings->push_back(CacheDeprecatedError_());
  }
  return CacheDeprecatedError_();
}

std::string TransferAppService::BuildTaskId_() {
  static std::atomic<uint64_t> seq{1};
  const uint64_t id = seq.fetch_add(1, std::memory_order_relaxed);
  return AMStr::fmt("T{}-{}", static_cast<uint64_t>(AMTime::miliseconds()), id);
}

std::pair<ECM, std::shared_ptr<TaskInfo>> TransferAppService::PrepareTasks_(
    const std::vector<UserTransferSet> &transfer_sets, bool quiet,
    const AMDomain::client::ClientControlComponent &control,
    std::vector<WildcardConfirmRequest> *confirm_requests,
    std::vector<ECM> *warnings) const {
  if (!filesystem_service_) {
    return {Err(EC::InvalidHandle, "Filesystem app service is not bound"),
            nullptr};
  }
  if (transfer_sets.empty()) {
    return {Err(EC::InvalidArg, "Transfer set list is empty"), nullptr};
  }

  std::vector<TransferTask> all_tasks = {};
  TransferClientContainer clients = {};
  std::unordered_set<std::string> nicknames = {};

  for (const auto &set : transfer_sets) {
    if (control.IsInterrupted()) {
      return {Err(EC::Terminate, "Interrupted before task generation"), nullptr};
    }
    if (control.IsTimeout()) {
      return {Err(EC::OperationTimeout, "Timeout before task generation"),
              nullptr};
    }

    if (confirm_requests) {
      for (const auto &src : set.srcs) {
        if (!src.is_wildcard) {
          continue;
        }
        auto find_result =
            filesystem_service_->find(src, SearchType::All, control);
        if (!isok(find_result.rcm)) {
          return {find_result.rcm, nullptr};
        }
        confirm_requests->push_back(
            {find_result.data, src.nickname, set.dst.nickname});
      }
    }

    auto resolved_dst = filesystem_service_->ResolveTransferDst(set.dst, control);
    if (!isok(resolved_dst.rcm)) {
      return {resolved_dst.rcm, nullptr};
    }

    auto resolved_src =
        filesystem_service_->ResolveTransferSrc(set.srcs, &clients, control, true);
    if (!isok(resolved_src.rcm)) {
      return {resolved_src.rcm, nullptr};
    }

    for (const auto &[nickname, transfer_path] : resolved_src.data.data) {
      if (transfer_path.client) {
        PutPrimaryClient_(&clients, nickname, transfer_path.client);
      }
      nicknames.insert(NormalizeHostKey_(nickname));
    }
    if (resolved_dst.data.client) {
      PutPrimaryClient_(&clients, resolved_dst.data.target.nickname,
                        resolved_dst.data.client);
      nicknames.insert(NormalizeHostKey_(resolved_dst.data.target.nickname));
    }

    AMApplication::filesystem::BuildTransferTaskOptions options = {};
    options.clone = set.clone;
    options.mkdir = set.mkdir;
    options.ignore_special_file = set.ignore_special_file;
    options.resume = set.resume;

    auto build_result = filesystem_service_->BuildTransferTasks(
        resolved_src.data, resolved_dst.data, control, options);
    if (!isok(build_result.rcm)) {
      return {build_result.rcm, nullptr};
    }
    for (auto &task : build_result.data.dir_tasks) {
      task.overwrite = set.overwrite;
    }
    for (auto &task : build_result.data.file_tasks) {
      task.overwrite = set.overwrite;
    }
    all_tasks.insert(all_tasks.end(), build_result.data.dir_tasks.begin(),
                     build_result.data.dir_tasks.end());
    all_tasks.insert(all_tasks.end(), build_result.data.file_tasks.begin(),
                     build_result.data.file_tasks.end());
    if (warnings) {
      for (const auto &warning : build_result.data.warnings) {
        warnings->push_back(
            Err(warning.rcm.first,
                AMStr::fmt("{} -> {}: {}", warning.src, warning.dst,
                           warning.rcm.second)));
      }
    }
  }

  for (const auto &task : all_tasks) {
    const std::string src_host = NormalizeHostKey_(task.src_host);
    const std::string dst_host = NormalizeHostKey_(task.dst_host);
    if (src_host != dst_host) {
      continue;
    }
    auto it = clients.find(src_host);
    if (it == clients.end()) {
      continue;
    }
    ClientHandle src_client = nullptr;
    if (std::holds_alternative<ClientHandle>(it->second)) {
      src_client = std::get<ClientHandle>(it->second);
    } else {
      auto pair_slot = std::get<std::pair<ClientHandle, ClientHandle>>(it->second);
      src_client = pair_slot.first ? pair_slot.first : pair_slot.second;
    }
    if (src_client) {
      PutSecondaryClient_(&clients, src_host, src_client);
    }
  }

  DedupTasks_(&all_tasks);
  if (all_tasks.empty()) {
    return {Err(EC::InvalidArg, "No transfer task generated"), nullptr};
  }

  auto task_info = std::make_shared<TaskInfo>();
  task_info->id = BuildTaskId_();
  task_info->Set.quiet = quiet;
  task_info->Core.control = control;
  task_info->Set.transfer_sets =
      std::make_shared<std::vector<UserTransferSet>>(transfer_sets);
  {
    auto task_lock = task_info->Core.tasks.lock();
    task_lock.store(all_tasks);
  }
  task_info->Core.clients = clients;
  task_info->Core.nicknames.assign(nicknames.begin(), nicknames.end());
  task_info->CalTotalSize(true);
  task_info->CalFileNum(true);
  return {Ok(), task_info};
}

ECM TransferAppService::ResolveWildcardConfirm_(
    const std::vector<WildcardConfirmRequest> &confirm_requests,
    TransferConfirmPolicy confirm_policy,
    const WildcardConfirmFn &confirm_wildcard) const {
  if (confirm_requests.empty()) {
    return Ok();
  }
  if (confirm_policy == TransferConfirmPolicy::AutoApprove) {
    return Ok();
  }
  if (confirm_policy == TransferConfirmPolicy::DenyIfConfirmNeeded) {
    return Err(EC::ConfigCanceled,
               "Transfer requires confirmation but session is non-interactive");
  }
  if (!confirm_wildcard) {
    return Err(EC::ConfigCanceled,
               "Transfer wildcard confirmation callback is not set");
  }
  for (const auto &request : confirm_requests) {
    const bool confirmed =
        confirm_wildcard(request.matches, request.src_host, request.dst_host);
    if (!confirmed) {
      return Err(EC::ConfigCanceled, "Transfer canceled by user");
    }
  }
  return Ok();
}

ECM TransferAppService::WaitTask_(
    const ID &task_id, const AMDomain::client::ClientControlComponent &control) const {
  if (!runtime_pool_) {
    return Err(EC::InvalidHandle, "Transfer runtime pool is not initialized");
  }
  while (true) {
    if (control.IsInterrupted()) {
      (void)runtime_pool_->Terminate(task_id, 1000);
      return Err(EC::Terminate, "Transfer interrupted");
    }
    if (control.IsTimeout()) {
      (void)runtime_pool_->Terminate(task_id, 1000);
      return Err(EC::OperationTimeout, "Transfer timeout");
    }

    std::shared_ptr<TaskInfo> done = runtime_pool_->GetResultTask(task_id, false);
    if (done) {
      return done->GetResult();
    }

    auto status = runtime_pool_->GetStatus(task_id);
    if (!status.has_value()) {
      return Err(EC::TaskNotFound, AMStr::fmt("Task not found: {}", task_id));
    }
    if (*status == TaskStatus::Finished) {
      done = runtime_pool_->GetResultTask(task_id, false);
      return done ? done->GetResult() : Ok();
    }
    std::this_thread::sleep_for(std::chrono::milliseconds(kTaskPollIntervalMs));
  }
}
} // namespace AMApplication::TransferWorkflow
