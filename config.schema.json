{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "private_keys": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "HOSTS": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "nickname",
          "hostname"
        ],
        "properties": {
          "nickname": {
            "type": "string"
          },
          "hostname": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "keyfile": {
            "type": "string"
          },
          "trash_dir": {
            "type": "string"
          },
          "protocol": {
            "type": "string"
          },
          "buffer_size": {
            "type": "integer"
          },
          "port": {
            "type": "integer"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}