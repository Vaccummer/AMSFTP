#pragma once
#include "TransferDomainModel.hpp"
#include "domain/transfer/TransferDomainModel.hpp"
#include <vector>

namespace AMDomain::transfer {

/**
 * @brief Pure domain service for cached transfer-set bookkeeping.
 */
class CacheService {
public:
  /**
   * @brief Append one transfer set and return new cache index.
   */
  static size_t AddTransferSet(Cache *cache,
                               const UserTransferSet &transfer_set);

  /**
   * @brief Query one cached transfer set by index.
   */
  static ECM QueryTransferSet(const Cache &cache, size_t set_index,
                              UserTransferSet *out_set);

  /**
   * @brief Return valid cache indices.
   */
  [[nodiscard]] static std::vector<size_t>
  ListTransferSetIds(const Cache &cache);

  /**
   * @brief Delete one cached transfer set by index.
   *
   * @param cache Cache storage to mutate.
   * @param set_index Requested index.
   * @param warning Optional warning for invalid/already-deleted index.
   * @return 1 when one entry transitioned from valid to deleted, otherwise 0.
   */
  static size_t DeleteTransferSet(Cache *cache, size_t set_index,
                                  ECM *warning = nullptr);

  /**
   * @brief Clear cache.
   */
  static void Clear(Cache *cache);

  /**
   * @brief Snapshot all valid cached transfer sets.
   */
  [[nodiscard]] static std::vector<UserTransferSet>
  SnapshotValidSets(const Cache &cache);
};

class TaskService {
public:
  static sptr<TaskInfo> GetHistoryTask(const TaskHistory &history,
                                       const TaskInfo::ID &task_id);

  static std::vector<TaskInfo::ID> GetHistoryIDs(const TaskHistory &history);
};
} // namespace AMDomain::transfer
